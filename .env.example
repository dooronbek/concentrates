# Copy to .env.local for local development.
# For Vercel deployment, set the production-required vars (section 2) in
# the Vercel dashboard — do NOT commit real values to this file.
#
# Three sections:
#   1. Local-dev only        — never set in Vercel
#   2. Production-required   — set in Vercel dashboard, also used locally
#   3. Local seed-script only — NEVER set in Vercel; service role bypasses RLS

# ============================================================================
# 1. LOCAL-DEV ONLY
# ============================================================================
# These control the offline mock mode used while iterating on UI without a
# Supabase round-trip. Mock mode is OPT-IN: the deployed app reads "unset"
# as "real Supabase", so leaving these out of Vercel is the correct
# production behavior. Do NOT set either of these in Vercel.
#
# Set VITE_USE_MOCK_API=true here to develop against the in-browser mock.
# Leave it commented out (or set to "false") to develop against live Supabase.

VITE_USE_MOCK_API=true
VITE_MOCK_PASSWORD=test123

# ============================================================================
# 2. PRODUCTION-REQUIRED  (paste these into Vercel → Project → Settings →
#    Environment Variables, scope: Production + Preview + Development)
# ============================================================================
# Public Supabase URL + anon key are exposed to the browser by design; the
# anon key is scoped by RLS and cannot bypass it. Operator email is the
# fixed account the login screen authenticates as.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_OPERATOR_EMAIL=operator@concentrates.local

# ============================================================================
# 3. LOCAL SEED-SCRIPT ONLY  —  NEVER SET IN VERCEL
# ============================================================================
# Used exclusively by `npm run db:seed`. The service role key bypasses RLS
# and grants god-mode access to the database — it must never be exposed to
# the browser, and it must never appear in the deployed app's environment.
# Keep it in your local .env.local only.
#
# SUPABASE_URL is the same URL as VITE_SUPABASE_URL above; duplicated here
# without the VITE_ prefix because the seed script runs in Node and only
# Vite-bundled code sees VITE_-prefixed vars.

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
